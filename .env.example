# ─────────────────────────────────────────────────────
# PulZ — Environment Variables Template
# Copy to .env.local and fill in your values.
# ─────────────────────────────────────────────────────

# ── Clerk ──────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# https://dashboard.clerk.com → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ── Supabase ───────────────────────────────────────────
# https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# DANGER: server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ─────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# https://dashboard.stripe.com → Webhooks → Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...
